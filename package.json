{
  "name": "aone-trust-simrs-hub",
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server-hub.ts",
    "build": "esbuild server-hub.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server-hub.mjs",
    "start": "node dist/server-hub.mjs",
    "seed": "tsx src/seed.ts",
    "frontend:install": "cd frontend && npm install",
    "frontend:build": "cd frontend && npm run build",
    "build:all": "npm run build && npm run frontend:install && npm run frontend:build",
    "start:all": "npm run build:all && npm start"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "esbuild": "^0.24.0",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "pg": "^8.13.0",
    "uuid": "^14.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
