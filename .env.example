# AONE TRUST SIMRS - VPS Hub (Render + Neon)
# Copy this to .env for local dev, or set these vars in Render Dashboard

NODE_ENV=production
PORT=4000
CORS_ORIGIN=*

# Neon PostgreSQL — pakai DATABASE_URL (recommended) atau PGHOST/PGPORT dll
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/simrs_hub?sslmode=require
# Atau manual:
# PGHOST=ep-xxxx.us-east-2.aws.neon.tech
# PGPORT=5432
# PGUSER=user
# PGPASSWORD=password
# PGDATABASE=simrs_hub
# PGSSLMODE=require

JWT_SECRET=ganti_dengan_string_acak_yang_aman
ADMIN_EMAIL=superadmin@aone-trust.com
ADMIN_PASSWORD=Admin123!

# Tunnel (websocket untuk koneksi RS lokal)
TUNNEL_PORT=4001
TUNNEL_TOKEN=ganti_dengan_token_acak

# Domain VPS (untuk virtual hosting)
# VPS_DOMAIN=hub.an domain.com
