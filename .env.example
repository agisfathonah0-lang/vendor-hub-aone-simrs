# ============================================================
#  AONE TRUST SIMRS - VPS Hub Configuration
# ============================================================
NODE_ENV=production
PORT=4000
CORS_ORIGIN=*

# PostgreSQL (multi-tenant — satu database untuk semua RS)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=change_me
PGDATABASE=simrs_hub

# JWT Secret untuk token API
JWT_SECRET=change_me_to_random_string

# Admin credentials (first-run seed)
ADMIN_EMAIL=superadmin@aone-trust.com
ADMIN_PASSWORD=Admin123!

# BPJS (opsional — bisa di masing-masing RS atau terpusat)
BPJS_CONSUMER_ID=
BPJS_CONSUMER_SECRET=
BPJS_USER_KEY=
BPJS_BASE_URL=https://apijkn.bpjs-kesehatan.go.id/vclaim-rest

# SatuSehat (opsional — bisa di masing-masing RS atau terpusat)
SATUSEHAT_CLIENT_ID=
SATUSEHAT_CLIENT_SECRET=
SATUSEHAT_ORGANIZATION_ID=
SATUSEHAT_BASE_URL=https://api-satusehat.kemkes.go.id/fhir-r4
SATUSEHAT_AUTH_URL=https://api-satusehat.kemkes.go.id/oauth2/v1/accesstoken

# Tunnel
TUNNEL_PORT=4001
TUNNEL_TOKEN=change_me_tunnel_secret
