# AONE TRUST SIMRS - VPS Hub (Render + Neon)
# Copy this to .env for local dev, or set these vars in Render Dashboard

NODE_ENV=production
PORT=4000

# CORS — daftar origin yg diizinkan, pisahkan dengan koma
# Dev default: http://localhost:5173
# Production: https://hub.domain-anda.com
CORS_ORIGINS=http://localhost:5173,https://hub.aone-trust.com

# Neon PostgreSQL — pakai DATABASE_URL (recommended) atau PGHOST/PGPORT dll
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/simrs_hub?sslmode=require

ADMIN_EMAIL=superadmin@aone-trust.com
# WAJIB: ganti dengan password kuat! Server akan reject jika tidak diisi.
ADMIN_PASSWORD=GantiDenganPasswordKuat123!

# Tunnel (websocket untuk koneksi RS lokal)
TUNNEL_PORT=4001
# WAJIB: ganti dengan token acak yang kuat!
TUNNEL_TOKEN=ganti_dengan_token_acak_panjang
